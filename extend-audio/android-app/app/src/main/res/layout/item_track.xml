<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:layout_marginBottom="12dp">

    <View
        android:id="@+id/viewTrackGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@drawable/bg_track_playing_glow" />

    <LinearLayout
        android:id="@+id/layoutTrackCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="4dp"
        android:layout_marginVertical="3dp"
        android:background="@drawable/bg_card_subtle"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_card"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <ImageView
                android:id="@+id/imageTrackArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/track_art"
                android:scaleType="centerCrop" />

            <ImageView
                android:id="@+id/imageTrackFallback"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/logo"
                android:padding="8dp"
                android:src="@drawable/extend_logo" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textTrackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Demo track" />

            <TextView
                android:id="@+id/textTrackMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="Unknown artist • 03:16" />
        </LinearLayout>

        <TextView
            android:id="@+id/textAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/track_item_action"
            android:textColor="@color/brand_cyan"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
