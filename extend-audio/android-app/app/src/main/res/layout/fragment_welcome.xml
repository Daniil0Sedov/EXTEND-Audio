<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_screen"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:id="@+id/topLeftGlow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginStart="-96dp"
        android:layout_marginTop="-84dp"
        android:alpha="0.28"
        android:background="@drawable/bg_welcome_orb_cyan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomRightGlow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginEnd="-128dp"
        android:layout_marginBottom="-8dp"
        android:alpha="0.20"
        android:background="@drawable/bg_welcome_orb_orange"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="82dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/footerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/logoContainer"
            android:layout_width="214dp"
            android:layout_height="214dp"
            android:layout_marginTop="2dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:layout_width="236dp"
                android:layout_height="236dp"
                android:layout_gravity="center"
                android:alpha="0.25"
                android:background="@drawable/bg_welcome_logo_glow_mist" />

            <View
                android:layout_width="184dp"
                android:layout_height="184dp"
                android:layout_gravity="center"
                android:alpha="0.22"
                android:background="@drawable/bg_welcome_logo_glow_inner" />

            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:alpha="0.14"
                android:background="@drawable/bg_welcome_logo_glow_outer" />

            <ImageView
                android:id="@+id/imageLogo"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/logo"
                android:src="@drawable/extend_logo" />
        </FrameLayout>

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/welcome_hero_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:maxWidth="290dp"
            android:text="@string/welcome_hero_subtitle"
            android:textColor="#C2D0D1"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/progressDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="34dp"
                android:layout_height="4dp"
                android:background="@drawable/bg_welcome_indicator_active" />

            <View
                android:layout_width="8dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_welcome_indicator_idle" />

            <View
                android:layout_width="8dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_welcome_indicator_idle" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:paddingBottom="94dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:maxWidth="336dp"
            android:clipChildren="false"
            android:clipToPadding="false">




            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonScan"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:drawablePadding="10dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="@string/scan_local_music"
                android:textAllCaps="false"
                android:textColor="#061214"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="#12DCEC"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart"
                app:iconTint="#061214" />
        </FrameLayout>

        <TextView
            android:id="@+id/buttonSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/skip_for_now"
            android:textAllCaps="true"
            android:textColor="#839596"
            android:textSize="12sp"
            android:letterSpacing="0.12"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/visualizerBars"
        android:layout_width="0dp"
        android:layout_height="124dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="-12dp"
        android:alpha="0.10"
        android:baselineAligned="false"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/bar1"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar2"
            android:layout_width="4dp"
            android:layout_height="86dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar3"
            android:layout_width="4dp"
            android:layout_height="54dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar4"
            android:layout_width="4dp"
            android:layout_height="108dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar5"
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar6"
            android:layout_width="4dp"
            android:layout_height="58dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar7"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar8"
            android:layout_width="4dp"
            android:layout_height="92dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar9"
            android:layout_width="4dp"
            android:layout_height="26dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />

        <View
            android:id="@+id/bar10"
            android:layout_width="4dp"
            android:layout_height="46dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_welcome_visualizer_bar" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
