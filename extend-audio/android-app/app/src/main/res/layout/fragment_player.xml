<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="36dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back_minimal"
                android:tint="@color/brand_cyan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textPlayerHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_header"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/buttonBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/buttonBack" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutCoverShell"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="18dp">

            <FrameLayout
                android:id="@+id/layoutCoverCard"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/bg_player_cover_card"
                android:clipChildren="false"
                android:clipToOutline="true"
                android:clipToPadding="false"
                android:outlineProvider="background"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.extend.audio.ui.player.TrackCardGlowView
                    android:id="@+id/viewCoverGlow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />

                <ImageView
                    android:id="@+id/imageCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="22dp"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_player_cover_image"
                    android:clipToOutline="true"
                    android:contentDescription="@string/track_art"
                    android:outlineProvider="background"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="22dp"
                    android:background="@drawable/bg_player_cover_scrim" />

                <ImageView
                    android:id="@+id/imageCoverFallback"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/logo"
                    android:src="@drawable/extend_logo" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/textTrackTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="Midnight Pulse" />

        <TextView
            android:id="@+id/textTrackArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            tools:text="Synthetix" />

        <SeekBar
            android:id="@+id/seekProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:max="100"
            android:progressBackgroundTint="@color/divider"
            android:progressTint="@color/brand_orange"
            android:splitTrack="false"
            android:thumbTint="@color/brand_orange" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="01:24" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/textDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="04:12" />
        </LinearLayout>

        <TextView
            android:id="@+id/textPreset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_subtle"
            android:paddingStart="14dp"
            android:paddingTop="7dp"
            android:paddingEnd="14dp"
            android:paddingBottom="7dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            tools:text="JBL Quantum 350" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonShuffle"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_player_toggle_button"
                android:contentDescription="@string/shuffle_playlist"
                android:padding="11dp"
                android:src="@drawable/ic_shuffle_minimal"
                android:tint="@color/player_toggle_icon_tint" />

            <ImageButton
                android:id="@+id/buttonRepeat"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_player_toggle_button"
                android:contentDescription="@string/repeat_track"
                android:padding="11dp"
                android:src="@drawable/ic_repeat_minimal"
                android:tint="@color/player_toggle_icon_tint" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonPrevious"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_player_secondary_button"
                android:contentDescription="@string/previous"
                android:padding="13dp"
                android:src="@drawable/ic_prev_minimal"
                android:tint="@color/player_minimal_icon_tint" />

            <FrameLayout
                android:layout_width="152dp"
                android:layout_height="152dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:foregroundGravity="center"
                android:padding="16dp">

                <com.extend.audio.ui.player.AudioPulseView
                    android:id="@+id/viewPlayButtonGlow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />

                <ImageButton
                    android:id="@+id/buttonPlayPause"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_player_primary_core"
                    android:contentDescription="@string/play"
                    android:padding="24dp"
                    android:src="@drawable/ic_play_minimal"
                    android:tint="@color/player_primary_icon_tint" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/buttonNext"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_player_secondary_button"
                android:contentDescription="@string/next"
                android:padding="13dp"
                android:src="@drawable/ic_next_minimal"
                android:tint="@color/player_minimal_icon_tint" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
