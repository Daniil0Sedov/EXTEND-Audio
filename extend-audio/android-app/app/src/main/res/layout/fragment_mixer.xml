<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="120dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mixer_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/mixer_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/textPresetStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/new_preset_label"
                android:textColor="@color/brand_cyan"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputPresetNameLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/preset_name_label"
                app:boxBackgroundColor="@color/bg_surface_alt"
                app:boxStrokeColor="@color/brand_cyan"
                app:hintTextColor="@color/text_secondary"
                app:placeholderText="@string/preset_name_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPresetName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    tools:text="Warm Night Mix" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputHeadphoneModelLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/headphone_model_label"
                app:boxBackgroundColor="@color/bg_surface_alt"
                app:boxStrokeColor="@color/brand_orange"
                app:hintTextColor="@color/text_secondary"
                app:placeholderText="@string/headphone_model_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editHeadphoneModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    tools:text="HyperX Cloud Alpha" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/textQuickHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/quick_edit_hint"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutEqualizerPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_subtle"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/textEqualizerHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mixer_panel_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutBandsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonApplyNow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/apply_now"
                android:textAllCaps="false"
                android:textColor="@color/bg_root"
                app:backgroundTint="@color/brand_cyan"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSavePreset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/save_preset"
                android:textAllCaps="false"
                android:textColor="@color/bg_root"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/brand_orange" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
